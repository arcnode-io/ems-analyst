# Template for secrets - copy to .env and fill in your values
# DO NOT commit .env to version control

# OpenWeatherMap API Key (required for weather tool — ADR-025)
# Get your free key from: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# gridstatus.io API key (required for get_market_data tool)
# Get a key from: https://www.gridstatus.io
GRIDSTATUS_API_KEY=

# ems-analyst-server base URL — agent reads telemetry + forecasts through it
# (principle: agent is just another client of server, same as HMI).
SERVER_URL=

# Site identifier baked into the deployment (CFN bake-time, per-customer).
# Telemetry queries are scoped to this site.
SITE_ID=

